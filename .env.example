# NoneBot2 基础配置
HOST=0.0.0.0
PORT=8080
SUPERUSERS=["你的QQ号"]
NICKNAME=["小助手", "bot"]
COMMAND_START=["/", ""]
COMMAND_SEP=["."]
LOG_LEVEL=INFO

# AI 对话配置
# 默认使用 doubao，可选 deepseek
AI_PROVIDER=doubao

# 豆包配置
ARK_API_KEY="你的豆包API_KEY"
DOUBAO_MODEL=doubao-seed-2-0-mini-260215

# DeepSeek 配置（备选）
DEEPSEEK_API_KEY="你的DeepSeek_API_KEY"
DEEPSEEK_MODEL=deepseek-chat
